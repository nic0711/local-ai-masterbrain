{
  "macros": [
    {
      "id": "light-mode",
      "label": "Leicht-Modus",
      "description": "Nur Open WebUI + n8n – spart Ressourcen",
      "actions": [
        {"action": "start",  "service": "open-webui"},
        {"action": "start",  "service": "n8n"},
        {"action": "stop",   "service": "neo4j"},
        {"action": "stop",   "service": "flowise"},
        {"action": "stop",   "service": "langfuse-web"},
        {"action": "stop",   "service": "langfuse-worker"}
      ]
    },
    {
      "id": "research",
      "label": "Research-Modus",
      "description": "Web-Research: SearXNG + Crawl4AI + Open WebUI",
      "actions": [
        {"action": "start",  "service": "searxng"},
        {"action": "start",  "service": "crawl4ai"},
        {"action": "start",  "service": "open-webui"},
        {"action": "start",  "service": "n8n"}
      ]
    },
    {
      "id": "rag-mode",
      "label": "RAG-Modus",
      "description": "Wissensarbeit: Qdrant + Neo4j + NLP + Open WebUI",
      "actions": [
        {"action": "start",  "service": "qdrant"},
        {"action": "start",  "service": "neo4j"},
        {"action": "start",  "service": "python-nlp-service"},
        {"action": "start",  "service": "open-webui"},
        {"action": "start",  "service": "n8n"}
      ]
    },
    {
      "id": "langfuse-start",
      "label": "Langfuse starten",
      "description": "LLM Observability: MinIO + ClickHouse + Langfuse",
      "actions": [
        {"action": "start",  "service": "minio"},
        {"action": "start",  "service": "clickhouse"},
        {"action": "start",  "service": "langfuse-web"},
        {"action": "start",  "service": "langfuse-worker"}
      ]
    },
    {
      "id": "save-resources",
      "label": "Ressourcen sparen",
      "description": "Schwere Dienste stoppen",
      "actions": [
        {"action": "stop",   "service": "neo4j"},
        {"action": "stop",   "service": "flowise"},
        {"action": "stop",   "service": "crawl4ai"},
        {"action": "stop",   "service": "langfuse-web"},
        {"action": "stop",   "service": "langfuse-worker"},
        {"action": "stop",   "service": "minio"},
        {"action": "stop",   "service": "clickhouse"}
      ]
    },
    {
      "id": "restart-core",
      "label": "Core neustarten",
      "description": "n8n + Open WebUI + Flowise neustarten",
      "actions": [
        {"action": "restart", "service": "n8n"},
        {"action": "restart", "service": "open-webui"},
        {"action": "restart", "service": "flowise"}
      ]
    },
    {
      "id": "hermes-start",
      "label": "Hermes Agent starten",
      "description": "KI-Agent starten (Gateway + Dashboard auf agent.brain.local)",
      "actions": [
        {"action": "start", "service": "hermes-gateway"},
        {"action": "start", "service": "hermes-dashboard"}
      ]
    },
    {
      "id": "hermes-stop",
      "label": "Hermes Agent stoppen",
      "description": "Hermes Gateway + Dashboard stoppen",
      "actions": [
        {"action": "stop", "service": "hermes-dashboard"},
        {"action": "stop", "service": "hermes-gateway"}
      ]
    },
    {
      "id": "monitoring-start",
      "label": "Monitoring starten",
      "description": "Prometheus + cAdvisor + node-exporter + Pushgateway starten",
      "actions": [
        {"action": "start", "service": "prometheus"},
        {"action": "start", "service": "node-exporter"},
        {"action": "start", "service": "cadvisor"},
        {"action": "start", "service": "pushgateway"}
      ]
    },
    {
      "id": "monitoring-stop",
      "label": "Monitoring stoppen",
      "description": "Prometheus-Stack stoppen",
      "actions": [
        {"action": "stop", "service": "pushgateway"},
        {"action": "stop", "service": "cadvisor"},
        {"action": "stop", "service": "node-exporter"},
        {"action": "stop", "service": "prometheus"}
      ]
    },
    {
      "id": "sps-start",
      "label": "SPS-Monitoring starten",
      "description": "MQTT + Modbus Exporter starten (Prometheus muss laufen)",
      "actions": [
        {"action": "start", "service": "mqtt2prometheus"},
        {"action": "start", "service": "modbus-exporter"}
      ]
    },
    {
      "id": "sps-stop",
      "label": "SPS-Monitoring stoppen",
      "description": "MQTT + Modbus Exporter stoppen",
      "actions": [
        {"action": "stop", "service": "mqtt2prometheus"},
        {"action": "stop", "service": "modbus-exporter"}
      ]
    }
  ]
}
