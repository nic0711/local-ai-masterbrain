# ################## #
#  Secrets & Config  #
# ################## #

# Ignoriere die zentrale .env-Datei, die alle Secrets enthält.
.env

# Ignoriere die dynamisch generierte Dashboard-Konfiguration, da sie Secrets enthalten kann.
dashboard/config.js

# ###################### #
#  Anwendungsdaten & DB  #
# ###################### #

# Ignoriere n8n-Backup-Dateien (Credentials), aber Workflows tracken
/n8n/backup/credentials/
/n8n/backup/*.json
# Workflows explizit tracken:
!/n8n/backup/workflows/

# Ignoriere die Daten- und Log-Verzeichnisse von Neo4j.
/neo4j/

# Ignoriere die Daten von Crawl4AI.
/crawl4ai-data/

# Ignoriere die Daten von Flowise (falls es in das Projektverzeichnis schreibt).
/.flowise/

# ################# #
#  Abhängigkeiten   #
# ################# #

# Ignoriere das geklonte Supabase-Repository, um Submodule-Konflikte zu vermeiden.
/supabase/

# Python-spezifische Ignorierungen
__pycache__/
*.pyc

# macOS-spezifische Systemdateien
.DS_Store

*.sql

volumes/
shared/
shared-backup/
searxng/settings.yml
searxng/uwsgi*

conversation_log.md
start_service Kopie.py
start_service_old.py
efactoring-attempt-7a435a6.patch
/backups/

# OCR storage runtime data (models, temp files, logs)
ocr_storage/temp/huggingface_cache/
ocr_storage/temp/*.log
ocr_storage/input/*
ocr_storage/output/*
!ocr_storage/input/.gitkeep
!ocr_storage/output/.gitkeep
!ocr_storage/temp/.gitkeep
