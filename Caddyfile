{
    # Global options - works for both environments
    email {$LETSENCRYPT_EMAIL}
}

# Security Headers Snippet – in jedem vHost mit `import security_headers` einbinden
(security_headers) {
    header {
        # HSTS – Browser erzwingt HTTPS für 1 Jahr
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Verhindert MIME-Type-Sniffing
        X-Content-Type-Options "nosniff"
        # Verhindert Clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Kein Referrer bei Cross-Origin-Requests
        Referrer-Policy "no-referrer-when-downgrade"
        # Browser-Feature-Einschränkungen
        Permissions-Policy "accelerometer=(), camera=(), geolocation=(), microphone=(), payment=()"
        # Server-Header entfernen (kein Fingerprinting)
        -Server
    }
}

# Protected Snippet – alle geschützten Services binden dies ein
# Liest sb-access-token Cookie und prüft ihn via auth-gateway
(protected) {
    forward_auth auth-gateway:5001 {
        uri /verify
        header_up Authorization "Bearer {http.request.cookie.sb-access-token}"
        copy_headers X-Forwarded-User
        @unauth status 401
        handle_response @unauth {
            redir https://{$DASHBOARD_HOSTNAME}/login.html?redirect={http.request.uri} 302
        }
    }
    import security_headers
}

# Dashboard – KEIN forward_auth, sonst Redirect-Loop
{$DASHBOARD_HOSTNAME} {
    import security_headers

    # Health-Status Proxy → auth-gateway (kein auth nötig, nur up/down-Info)
    handle /_status {
        rewrite * /status
        reverse_proxy auth-gateway:5001
    }

    # Backup-Control – JWT-Verifizierung erfolgt im auth-gateway selbst
    handle /_control/backup/status {
        rewrite * /control/backup/status
        reverse_proxy auth-gateway:5001
    }
    handle /_control/backup {
        rewrite * /control/backup
        reverse_proxy auth-gateway:5001
    }

    reverse_proxy dashboard-ui:80
}

# N8N
{$N8N_HOSTNAME} {
    import protected
    reverse_proxy n8n:5678

    # Logging
    log {
        output file /data/logs/n8n_access.log {
            roll_size 10mb
            roll_keep 5
        }

        output file /data/logs/n8n_error.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}

# Python NLP Service
{$NLP_HOSTNAME:nlp.invalid} {
    import protected
    reverse_proxy python-nlp-service:5000 {
        transport http {
            response_header_timeout 60s
        }
    }
}

