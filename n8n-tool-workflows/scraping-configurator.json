    {
      "parameters": {
        "jsCode": "// Normalise crawl4ai response into a flat content object\nconst input = $input.first().json;\nconst params = $('validate-input').first().json;\n\nlet content = '';\nlet title = '';\n\nif (input.results && input.results.length > 0) {\n  const r = input.results[0];\n  content = r.extracted_content || r.markdown || r.cleaned_html || '';\n  title = r.metadata?.title || r.title || new URL(params.url).hostname;\n} else if (input.result) {\n  content = input.result.extracted_content || input.result.markdown || '';\n  title = input.result.title || new URL(params.url).hostname;\n}\n\nif (!content) throw new Error('No content extracted from ' + params.url);\n\nreturn {\n  json: {\n    url: params.url,\n    title,\n    content,\n    content_length: content.length,\n    destination: params.destination,\n    collection: params.collection,\n    webhook_url: params.webhook_url,\n    metadata: params.metadata,\n    request_id: params.request_id,\n    scraped_at: new Date().toISOString(),\n    mode_used: params.mode\n  }\n};"
      },
