        "sendBody": true,
        "bodyContentType": "json",
        "jsonBody": "={\n  \"urls\": [\"{{ $json.url }}\"],\n  \"extraction_strategy\": \"CSSExtractionStrategy\",\n  \"extraction_config\": {\n    \"type\": \"schema\",\n    \"params\": {\n      \"schema\": {\n        \"name\": \"content\",\n        \"baseSelector\": \"{{ $json.css_selector || 'body' }}\",\n        \"fields\": [\n          { \"name\": \"text\", \"selector\": \"\", \"type\": \"text\" },\n          { \"name\": \"links\", \"selector\": \"a\", \"type\": \"list\", \"fields\": [{ \"name\": \"href\", \"selector\": \"\", \"type\": \"attribute\", \"attribute\": \"href\" }] }\n        ]\n      }\n    }\n  },\n  \"chunking_strategy\": \"RegexChunking\",\n  \"chunk_size\": 1000,\n  \"chunk_overlap\": 200\n}",
        "options": {
          "timeout": 60000,
          "retry": { "enabled": true, "maxRetries": 2 }
        }
      },
