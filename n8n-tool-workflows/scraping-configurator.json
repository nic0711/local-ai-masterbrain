    {
      "parameters": {
        "jsCode": "// Validate and normalise input\nconst body = $input.first().json.body || $input.first().json;\n\nconst url = body.url;\nconst mode = body.mode || 'auto';\nconst destination = body.destination || 'supabase';\nconst cssSelector = body.css_selector || '';\nconst llmInstruction = body.llm_instruction || 'Extract the main content, headings, and key information from this webpage.';\nconst collection = body.collection || 'default';\nconst webhookUrl = body.webhook_url || '';\nconst metadata = body.metadata || {};\n\n// Validation\nif (!url) throw new Error('Missing required field: url');\nif (!['css', 'llm', 'auto'].includes(mode)) throw new Error('Invalid mode. Must be: css | llm | auto');\nconst validDest = ['supabase', 'neo4j', 'qdrant', 'sheets', 'webhook', 'all'];\nif (!validDest.includes(destination)) throw new Error('Invalid destination. Must be: ' + validDest.join(' | '));\nif (destination === 'webhook' && !webhookUrl) throw new Error('webhook_url is required when destination=webhook');\n\nreturn {\n  json: {\n    url, mode, destination,\n    css_selector: cssSelector,\n    llm_instruction: llmInstruction,\n    collection, webhook_url: webhookUrl,\n    metadata,\n    request_id: 'sc_' + Date.now()\n  }\n};"
      },
      "id": "validate-input",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 400]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [
                  {
                    "leftValue": "={{ $json.mode }}",
                    "rightValue": "css",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "css"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false },
                "conditions": [
