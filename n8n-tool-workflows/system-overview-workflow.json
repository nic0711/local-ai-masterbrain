    {
      "parameters": {
        "jsCode": "// System Overview Dashboard\nconst userStats = $input.first().json;\nconst fileStats = $input.all()[1].json;\nconst workflowStats = $input.all()[2].json;\nconst ocrStats = $input.all()[3].json;\nconst aiStats = $input.all()[4].json;\nconst neo4jStats = $input.all()[5].json;\n\n// Calculate metrics\nconst dashboard = {\n  timestamp: new Date().toISOString(),\n  system_status: 'healthy',\n  \n  // User Management\n  users: {\n    total: userStats.length,\n    active_today: userStats.filter(u => \n      new Date(u.last_login_at) > new Date(Date.now() - 24*60*60*1000)\n    ).length,\n    new_this_week: userStats.filter(u => \n      new Date(u.created_at) > new Date(Date.now() - 7*24*60*60*1000)\n    ).length\n  },\n  \n  // File Management\n  files: {\n    total: fileStats.length,\n    total_size_mb: Math.round(fileStats.reduce((sum, f) => sum + (f.file_size || 0), 0) / 1024 / 1024),\n    uploaded_today: fileStats.filter(f => \n      new Date(f.created_at) > new Date(Date.now() - 24*60*60*1000)\n    ).length,\n    by_type: fileStats.reduce((acc, f) => {\n      const type = f.file_type || 'unknown';\n      acc[type] = (acc[type] || 0) + 1;\n      return acc;\n    }, {})\n  },\n  \n  // Workflow Management\n  workflows: {\n    total: workflowStats.length,\n    active: workflowStats.filter(w => w.status === 'active').length,\n    executions_today: workflowStats.filter(w => \n      new Date(w.last_execution_at) > new Date(Date.now() - 24*60*60*1000)\n    ).length,\n    success_rate: workflowStats.length > 0 ? \n      Math.round((workflowStats.filter(w => w.status === 'completed').length / workflowStats.length) * 100) : 0\n  },\n  \n  // OCR Performance\n  ocr: {\n    total_processed: ocrStats.length,\n    processed_today: ocrStats.filter(o => \n      new Date(o.created_at) > new Date(Date.now() - 24*60*60*1000)\n    ).length,\n    avg_confidence: ocrStats.length > 0 ? \n      Math.round(ocrStats.reduce((sum, o) => sum + (o.confidence_score || 0), 0) / ocrStats.length * 100) / 100 : 0,\n    avg_processing_time_ms: ocrStats.length > 0 ? \n      Math.round(ocrStats.reduce((sum, o) => sum + (o.processing_time_ms || 0), 0) / ocrStats.length) : 0,\n    engines_used: ocrStats.reduce((acc, o) => {\n      const engine = o.engine_used || 'unknown';\n      acc[engine] = (acc[engine] || 0) + 1;\n      return acc;\n    }, {})\n  },\n  \n  // AI Integration\n  ai: {\n    total_conversations: aiStats.length,\n    conversations_today: aiStats.filter(a => \n      new Date(a.created_at) > new Date(Date.now() - 24*60*60*1000)\n    ).length,\n    models_used: aiStats.reduce((acc, a) => {\n      const model = a.model_used || 'unknown';\n      acc[model] = (acc[model] || 0) + 1;\n      return acc;\n    }, {}),\n    avg_tokens_per_conversation: aiStats.length > 0 ? \n      Math.round(aiStats.reduce((sum, a) => sum + (a.total_tokens || 0), 0) / aiStats.length) : 0\n  },\n  \n  // Neo4j Integration\n  neo4j: {\n    total_queries: neo4jStats.length,\n    queries_today: neo4jStats.filter(n => \n      new Date(n.executed_at) > new Date(Date.now() - 24*60*60*1000)\n    ).length,\n    avg_execution_time_ms: neo4jStats.length > 0 ? \n      Math.round(neo4jStats.reduce((sum, n) => sum + (n.execution_time_ms || 0), 0) / neo4jStats.length) : 0,\n    successful_queries: neo4jStats.filter(n => n.status === 'success').length\n  },\n  \n  // System Health\n  health: {\n    database: 'connected',\n    ocr_service: 'running',\n    neo4j: 'connected',\n    n8n: 'running'\n  }\n};\n\nreturn { json: dashboard };"
      },
