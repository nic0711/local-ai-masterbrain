    {
      "parameters": {
        "jsCode": "// Health Check Results\nconst ocrHealth = $input.first().json;\nconst neo4jHealth = $input.all()[1].json;\nconst supabaseHealth = $input.all()[2].json;\n\nconst healthReport = {\n  timestamp: new Date().toISOString(),\n  overall_status: 'healthy',\n  services: {\n    ocr_service: {\n      status: ocrHealth.status === 'healthy' ? 'healthy' : 'unhealthy',\n      url: 'http://localhost:8002',\n      engines: ocrHealth.engines || {},\n      available_engines: ocrHealth.available_engines || []\n    },\n    neo4j: {\n      status: neo4jHealth ? 'healthy' : 'unhealthy',\n      url: 'http://localhost:7474',\n      version: neo4jHealth?.neo4j_version || 'unknown'\n    },\n    supabase: {\n      status: supabaseHealth ? 'healthy' : 'unhealthy',\n      url: 'http://localhost:54321',\n      description: supabaseHealth?.description || 'Supabase API'\n    },\n    n8n: {\n      status: 'healthy',\n      url: 'http://localhost:5678',\n      description: 'n8n Workflow Automation'\n    }\n  },\n  response_times: {\n    ocr_service_ms: 0, // Would need timing logic\n    neo4j_ms: 0,\n    supabase_ms: 0\n  }\n};\n\n// Determine overall status\nconst services = Object.values(healthReport.services);\nif (services.some(s => s.status === 'unhealthy')) {\n  healthReport.overall_status = 'degraded';\n}\nif (services.filter(s => s.status === 'unhealthy').length > 1) {\n  healthReport.overall_status = 'unhealthy';\n}\n\nreturn { json: healthReport };"
      },
