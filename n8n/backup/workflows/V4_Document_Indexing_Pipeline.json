    {
      "parameters": {
        "method": "POST",
        "url": "http://python-nlp-service:5000/process",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "text",
              "value": "={{ $json.body.text }}"
            },
            {
