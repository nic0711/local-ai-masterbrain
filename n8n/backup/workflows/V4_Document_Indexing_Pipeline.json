              "value": "50"
            }
          ]
        },
        "options": {}
      },
      "id": "nlp-extract-pdf",
      "name": "NLP: Text chunken (PDF/Text)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 400]
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineAll",
        "options": {}
      },
      "id": "merge-chunks",
      "name": "Chunks zusammenführen",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "jsCode": "const chunks = $input.all().flatMap(item => {\n  const data = item.json;\n  if (Array.isArray(data.chunks)) return data.chunks;\n  if (Array.isArray(data)) return data;\n  return [data];\n});\n\nreturn chunks.map((chunk, i) => ({\n  json: {\n    chunk_index: i,\n    text: typeof chunk === 'string' ? chunk : chunk.text || JSON.stringify(chunk)\n  }\n}));"
      },
      "id": "flatten-chunks",
      "name": "Chunks flatten",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://ollama:11434/api/embeddings",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "nomic-embed-text"
            },
            {
              "name": "prompt",
              "value": "={{ $json.text }}"
            }
          ]
        },
        "options": {}
      },
      "id": "embed-chunk",
      "name": "Ollama: Embedding erzeugen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst collectionName = $('Webhook: Dokument empfangen').first().json.body.collection || 'documents';\n\nconst points = items.map((item, i) => ({\n  id: Date.now() + i,\n  vector: item.json.embedding,\n  payload: {\n    text: item.json.text || '',\n    chunk_index: item.json.chunk_index || i,\n    source: $('Webhook: Dokument empfangen').first().json.body.url ||\n            $('Webhook: Dokument empfangen').first().json.body.source ||\n            'manual',\n    indexed_at: new Date().toISOString()\n  }\n}));\n\nreturn [{ json: { collection: collectionName, points } }];"
      },
      "id": "build-qdrant-payload",
      "name": "Qdrant Payload bauen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=http://qdrant:6333/collections/{{ $json.collection }}/points",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "points",
              "value": "={{ $json.points }}"
            }
          ]
        },
        "options": {}
      },
      "id": "upsert-qdrant",
      "name": "Qdrant: Punkte einfügen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2000, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"status\": \"ok\", \"indexed_chunks\": $('Qdrant: Punkte einfügen').first().json.result?.operation_id ?? 0, \"collection\": $('Qdrant Payload bauen').first().json.collection } }}"
      },
      "id": "respond-success",
      "name": "Antwort senden",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [2220, 300]
    }
  ],
