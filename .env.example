# ══════════════════════════════════════════════════════════════════
#  LOCAL AI MASTERBRAIN – Konfiguration
#  Datei umbenennen: cp .env.example .env
# ══════════════════════════════════════════════════════════════════
#
#  Secrets generieren (Linux/Mac):  openssl rand -hex 32
#  Supabase JWT-Keys generieren:    https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#
# ══════════════════════════════════════════════════════════════════
#
#  PFLICHTFELDER – alle Werte hier eintragen bevor du startest
#
# ══════════════════════════════════════════════════════════════════

STUDIO_DEFAULT_ORGANIZATION=ORG_Name

DISABLE_SIGNUP=false                        # Produktion: auf true setzen nach erstem User-Setup
# Supabase Mailer ggf. anpassen bei Production!!

# ── n8n ──────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=your-super-secret-and-long-key                     # openssl rand -hex 32
N8N_USER_MANAGEMENT_JWT_SECRET=your-super-secret-and-long-key         # openssl rand -hex 32

# ── Supabase – Datenbank & Auth ──────────────────────────────────
# Kein % Sonderzeichen im Postgres-Passwort verwenden
POSTGRES_PASSWORD=your-super-secret-and-long-key           # openssl rand -hex 16 (= genau 32 Zeichen)
JWT_SECRET=your-super-secret-and-long-key                  # openssl rand -hex 32
ANON_KEY=SECRET                                            # aus JWT-Key-Generator (URL oben)
SERVICE_ROLE_KEY=SECRET                                    # aus JWT-Key-Generator (URL oben)
DASHBOARD_USERNAME=USERNAME                                # Supabase Studio Login
DASHBOARD_PASSWORD=your-super-secret-and-long-key          # openssl rand -hex 16 (= genau 32 Zeichen)  
POOLER_TENANT_ID=242342                                    # beliebige Zahl

# ── Supabase – interne Secrets ───────────────────────────────────
SECRET_KEY_BASE=your-super-secret-and-long-key                                          # openssl rand -hex 64
VAULT_ENC_KEY=your-32-character-key                                                     # openssl rand -hex 16 (= genau 32 Zeichen)
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-public             # openssl rand -hex 32
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-private           # openssl rand -hex 32 (verschieden von PUBLIC)

# ── Neo4j ────────────────────────────────────────────────────────
NEO4J_AUTH=neo4j/your-super-secret-and-long-key            # Format: benutzer/passwort # openssl rand -hex 16 (= genau 32 Zeichen)

# ── Langfuse ─────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=your-super-secret-and-long-key              # openssl rand -hex 32
CLICKHOUSE_PASSWORD=your-super-secret-and-long-key              # openssl rand -hex 32
LANGFUSE_SALT=your-super-secret-and-long-key                    # openssl rand -hex 32
NEXTAUTH_SECRET=your-super-secret-and-long-key                  # openssl rand -hex 32
ENCRYPTION_KEY=your-super-secret-and-long-key                   # openssl rand -hex 32

# ── Flowise – Basic Auth ─────────────────────────────────────────
FLOWISE_USERNAME=USERNAME
FLOWISE_PASSWORD=your-super-secret-and-long-key                 # openssl rand -hex 16 (= genau 32 Zeichen)

# ── Whisper STT (Open WebUI) ──────────────────────────────────────
# Modell für Speech-to-Text (faster-whisper, läuft direkt im open-webui Container)
# tiny (~75 MB)  · base (~150 MB)  · small (~500 MB)  · medium (~1.5 GB)  · large-v3 (~3 GB)
# Für Deutsch empfohlen: medium (gute Qualität, akzeptable Geschwindigkeit)
#                        large-v3 (beste Qualität, langsamer, braucht mehr RAM)
# Ändern: Wert anpassen → docker compose -p localai up -d open-webui
WHISPER_MODEL=medium

S3_PROTOCOL_ACCESS_KEY_ID=your-32-char-access-key-id-here      # openssl rand -hex 16
S3_PROTOCOL_ACCESS_KEY_SECRET=your-64-char-access-key-secret-here-replace-before-use      # openssl rand -hex 32

# ── Domain & Hostnamen ───────────────────────────────────────────
#
#  LOKAL (aktiv):
#    - /etc/hosts:  127.0.0.1  brain.local  n8n.brain.local  webui.brain.local  flowise.brain.local
#                              supabase.brain.local  langfuse.brain.local  neo4j.brain.local
#                              crawl.brain.local  search.brain.local
#                              qdrant.brain.local  minio.brain.local
#
DOMAIN=brain.local

DASHBOARD_HOSTNAME=brain.local
N8N_HOSTNAME=n8n.brain.local
WEBUI_HOSTNAME=webui.brain.local
FLOWISE_HOSTNAME=flowise.brain.local
SUPABASE_HOSTNAME=supabase.brain.local
LANGFUSE_HOSTNAME=langfuse.brain.local
NEO4J_HOSTNAME=neo4j.brain.local
CRAWL4AI_HOSTNAME=crawl.brain.local
SEARXNG_HOSTNAME=search.brain.local
QDRANT_HOSTNAME=qdrant.brain.local
MINIO_HOSTNAME=minio.brain.local
# OLLAMA_HOSTNAME=ollama.brain.local     # optional
# NLP_HOSTNAME=nlp.brain.local           # optional: Python NLP Service via Caddy (Profil: public)
# OCR_HOSTNAME=ocr.brain.local           # optional: TrOCR/Surya/Tesseract OCR Service via Caddy
# UPTIME_KUMA_HOSTNAME=status.brain.local # optional: Uptime Kuma Monitoring (Profil: monitoring)

LETSENCRYPT_EMAIL=internal

#  PRODUKTION (auskommentiert – für Server aktivieren):
#
# DOMAIN=yourdomain.com
# DASHBOARD_HOSTNAME=brain.yourdomain.com
# N8N_HOSTNAME=n8n.yourdomain.com
# WEBUI_HOSTNAME=webui.yourdomain.com
# FLOWISE_HOSTNAME=flowise.yourdomain.com
# SUPABASE_HOSTNAME=supabase.yourdomain.com
# LANGFUSE_HOSTNAME=langfuse.yourdomain.com
# NEO4J_HOSTNAME=neo4j.yourdomain.com
# CRAWL4AI_HOSTNAME=crawl.yourdomain.com
# QDRANT_HOSTNAME=qdrant.yourdomain.com
# MINIO_HOSTNAME=minio.yourdomain.com
# NLP_HOSTNAME=nlp.yourdomain.com
# UPTIME_KUMA_HOSTNAME=status.yourdomain.com
# LETSENCRYPT_EMAIL=info@yourdomain.com


# ══════════════════════════════════════════════════════════════════
#  OPTIONAL – Standardwerte reichen für die meisten Setups
# ══════════════════════════════════════════════════════════════════

# ── Backup Scheduling (Profil: backup) ───────────────────────────
# BACKUP_SCHEDULE=0 3 * * *          # Cron-Ausdruck (Standard: täglich 03:00 Uhr)
# BACKUP_RETENTION_DAYS=7            # Backups älter als N Tage werden gelöscht

# ── SearXNG Performance ──────────────────────────────────────────
SEARXNG_UWSGI_WORKERS=4
SEARXNG_UWSGI_THREADS=4

# ── Python NLP / Document Service ───────────────────────────────
OLLAMA_HOST=http://host.docker.internal:11434   # Mac: host.docker.internal | Server: http://ollama:11434
# OLLAMA_HOST=http://ollama:11434               # wenn Ollama im selben Docker-Setup läuft – optional  
OCR_MODEL=glm-ocr                               # Modell vorab pullen: ollama pull glm-ocr

# ── OpenAI (fuer Supabase SQL-Editor-Assistent) ──────────────────
# OPENAI_API_KEY=

# ── Google OAuth fuer Supabase ───────────────────────────────────
# ENABLE_GOOGLE_SIGNUP=true
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=


# ══════════════════════════════════════════════════════════════════
#  DEFAULTS – nicht aendern ausser du weisst was du tust
# ══════════════════════════════════════════════════════════════════

# Supabase Storage (Datei-basiert, kein S3 noetig)
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub

# Supabase Auth (GoTrue)
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
API_EXTERNAL_URL=http://localhost:8000
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

# Supabase Mailer (lokaler Dummy-SMTP)
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

# Supabase Studio
STUDIO_DEFAULT_PROJECT=internal
STUDIO_PORT=3000
SUPABASE_PUBLIC_URL=http://localhost:8000
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Supabase Pooler (Supavisor)
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=5

# Kong API Proxy
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# PostgREST
PGRST_DB_SCHEMAS=public,storage,graphql_public

# Supabase Functions
FUNCTIONS_VERIFY_JWT=false

# Docker
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# Google Cloud (nur fuer Supabase Analytics – optional)
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER
